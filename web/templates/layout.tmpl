<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{if .PageTitle}}{{.PageTitle}} - {{end}}{{.SiteTitle}}</title>
  <script src="/assets/vendor/tailwindcss.cdn.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              50: "#f0f9ff",
              500: "#0ea5e9",
              600: "#0284c7"
            }
          }
        }
      }
    };
  </script>
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body class="bg-slate-50 text-slate-800 antialiased">
  <header class="sticky top-0 z-30 border-b border-slate-200 bg-white/95 backdrop-blur">
    <div class="mx-auto flex h-16 w-full items-center justify-between px-4 lg:px-6">
      <div class="text-lg font-bold tracking-tight text-slate-900">{{.SiteTitle}}</div>
      <div class="relative w-[22rem] max-w-[65vw]">
        <input id="searchInput" class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20" placeholder="搜索文档...">
        <div id="searchResultTop" class="absolute right-0 top-14 z-40 w-[36rem] max-w-[90vw] max-h-[55vh] overflow-auto rounded-xl border border-slate-200 bg-white p-2 shadow-xl"></div>
      </div>
    </div>
  </header>
  <main class="grid min-h-[calc(100vh-4rem)] w-full grid-cols-1 lg:grid-cols-[350px_minmax(0,1fr)]">
    <aside class="border-b border-slate-200 bg-white px-2 py-4 scroll-pt-3 scroll-pb-3 lg:sticky lg:top-16 lg:h-[calc(100vh-4rem)] lg:overflow-y-auto lg:border-b-0 lg:border-r">
      <nav class="space-y-1">
        {{range $i, $item := .Nav}}
          {{if $item.Children}}
            <button
              type="button"
              class="nav-accordion-toggle flex w-full items-center justify-between rounded-md px-2 py-2 text-left text-sm text-slate-700 transition hover:bg-slate-100"
              data-accordion-target="nav-group-{{$i}}"
              aria-expanded="{{if isActivePrefix $.Current $item.Route}}true{{else}}false{{end}}"
            >
              <span>{{$item.Title}}</span>
              <span class="nav-accordion-icon text-slate-400 {{if isActivePrefix $.Current $item.Route}}rotate-90{{end}}">
                <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M4 2L8 6L4 10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </button>
            <div id="nav-group-{{$i}}" class="nav-accordion-panel ml-3 {{if not (isActivePrefix $.Current $item.Route)}}hidden {{end}}space-y-1 border-l border-slate-200 pl-2">
              {{range $j, $child := $item.Children}}
                {{if $child.Children}}
                  <div class="space-y-1">
                    <a
                      data-inactive-color="text-slate-600"
                      data-sub-accordion-link="nav-sub-group-{{$i}}-{{$j}}"
                      data-sub-accordion-parent="nav-group-{{$i}}"
                      class="nav-link flex items-center justify-between rounded-md px-2 py-1.5 text-sm transition {{if eq $.Current $child.Route}}bg-brand-50 text-brand-600 font-semibold{{else}}text-slate-600 hover:bg-slate-100{{end}}"
                      href="{{$child.Route}}"
                      title="{{$child.Title}}"
                    >
                      <span class="min-w-0 truncate" title="{{$child.Title}}">{{$child.Title}}</span>
                      <span class="nav-sub-accordion-icon text-slate-400 {{if isActivePrefix $.Current $child.Route}}rotate-90{{end}}">
                        <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M4 2L8 6L4 10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                    </a>
                    <div id="nav-sub-group-{{$i}}-{{$j}}" class="nav-sub-accordion-panel ml-3 {{if not (isActivePrefix $.Current $child.Route)}}hidden {{end}}space-y-1 border-l border-slate-200 pl-2">
                      {{range $child.Children}}
                        <a data-inactive-color="text-slate-500" class="nav-link block truncate rounded-md px-2 py-1 text-sm text-slate-500 transition hover:bg-slate-100" href="{{.Route}}" title="{{.Title}}">{{.Title}}</a>
                        {{if .Children}}
                          <div class="ml-3 space-y-1 border-l border-slate-200 pl-2">
                            {{range .Children}}
                              <a data-inactive-color="text-slate-500" class="nav-link block truncate rounded-md px-2 py-1 text-sm text-slate-500 transition hover:bg-slate-100" href="{{.Route}}" title="{{.Title}}">{{.Title}}</a>
                            {{end}}
                          </div>
                        {{end}}
                      {{end}}
                    </div>
                  </div>
                {{else}}
                  <a data-inactive-color="text-slate-600" class="nav-link block rounded-md px-2 py-1.5 text-sm transition {{if eq $.Current $child.Route}}bg-brand-50 text-brand-600 font-semibold{{else}}text-slate-600 hover:bg-slate-100{{end}}" href="{{$child.Route}}">{{$child.Title}}</a>
                {{end}}
              {{end}}
            </div>
          {{else}}
            <a data-inactive-color="text-slate-700" class="nav-link block rounded-md px-2 py-2 text-sm transition {{if eq $.Current $item.Route}}bg-brand-50 text-brand-600 font-semibold{{else}}text-slate-700 hover:bg-slate-100{{end}}" href="{{$item.Route}}">{{$item.Title}}</a>
          {{end}}
        {{end}}
      </nav>
    </aside>
    <article class="markdown-body mx-auto w-full max-w-4xl px-5 py-6 lg:px-10 lg:py-8">
      {{.Content}}
    </article>
  </main>
  <script src="/assets/vendor/mermaid.min.js"></script>
  <script src="/assets/search.js"></script>
  <script src="/assets/nav.js"></script>
  <script src="/assets/mermaid-init.js"></script>
  <script src="/assets/kroki-lightbox.js"></script>
</body>
</html>
